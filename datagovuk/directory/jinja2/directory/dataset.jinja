{% extends "base.jinja" %}

{% from "macros/common.jinja" import dataset_table_body, table %}

{% set page_title = "Dataset" %}

{% block main %}
  <div class="govuk-width-container datagovuk-width-container">

    <h1 class="govuk-heading-xl datagovuk-heading-xl">{{ title }}</h1>
    <dl class="govuk-summary-list">
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Published by</dt>
        <dd class="govuk-summary-list__value">
          {{ organization_title }}
        </dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Last updated</dt>
        <dd class="govuk-summary-list__value">
          {{ metadata_modified }}
        </dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Topic</dt>
        <dd class="govuk-summary-list__value">
        </dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Licence</dt>
        <dd class="govuk-summary-list__value">
        </dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Summary</dt>
        <dd class="govuk-summary-list__value">
          {{ notes }}
        </dd>
      </div>
    </dl>
    <h2 class="govuk-heading-l datagovuk-heading-l">Data links</h2>
    {% if resources %}
      <div class="govuk-!-margin-bottom-8">
        <div class="datagovuk-table-container" tabindex="0">
          <table class="govuk-table datagovuk-table">
            {%- if table_headings %}
              <thead class="govuk-table__head datagovuk-table__head">
                <tr class="govuk-table__row">
                  {%- for heading in table_headings %}
                    <th scope="col"
                        class="govuk-table__header{% if heading.format == 'numeric' %} govuk-table__header--numeric{% endif %} datagovuk-table__header govuk-body datagovuk-body">
                      {{- heading.text -}}
                    </th>
                  {%- endfor %}
                </tr>
              </thead>
            {%- endif %}
            <tbody class="govuk-table__body">
              {% for resource in resources %}
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell datagovuk-table__cell govuk-body datagovuk-body">
                    <a href="{{ resource.url }}" class="govuk-link datagovuk-link">{{ resource.name }}</a>
                    {% if resource.file_size %}({{ resource.file_size }}){% endif %}
                  </td>
                  <td class="govuk-table__cell datagovuk-table__cell govuk-body datagovuk-body">{{ resource.format }}</td>
                  <td class="govuk-table__cell datagovuk-table__cell govuk-body datagovuk-body">
                    {% if resource.is_csv %}
                      <a href="{{ resource.preview_url }}" class="govuk-link datagovuk-link">Preview</a>
                    {% else %}
                      Not available
                    {% endif %}
                  </td>
                  <td class="govuk-table__cell datagovuk-table__cell govuk-body datagovuk-body">{{ resource.date }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <p class="govuk-body datagovuk-body">This data hasn’t been released by the publisher.</p>
    {% endif %}
  </div>
{% endblock main %}
