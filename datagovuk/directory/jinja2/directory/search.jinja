{% extends "base.jinja" %}

{% set page_title = "Search" %}

{% block main %}
  <div class="govuk-width-container datagovuk-width-container">
    <form method="get">
      {{ form }}
      <input type="submit" value="Submit" />
    </form>
    {% if results %}
      Hits: {{ results.hits }}
      {% for result in results %}
        <p>
          <a href="{{ url('directory:dataset', kwargs={'uuid': result.id, 'slug': result.name}) }}"
             class="govuk-link datagovuk-link">{{ result.title }}</a>
          <br />
          Publisher: {{ result.organization }}
          <br />
          Topic: {{ result["extras_theme-primary"]|default("Not set") }}

        </p>
      {% endfor %}
    {% endif %}
  </div>
{% endblock main %}
