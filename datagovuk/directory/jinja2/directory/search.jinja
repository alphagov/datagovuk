{% extends "base.jinja" %}

{% set page_title = "Search" %}

{% block main %}
  <div class="govuk-width-container datagovuk-width-container">
    <form method="get">
      <label for="query">Search:</label>
      <input type="text" id="query" name="q" placeholder="Type here..." />

      <button type="submit">Submit</button>
    </form>
    {% if results %}
      Hits: {{ results.hits }}
      {% for result in results %}
        <p>
          <a href="{{ url('directory:dataset', kwargs={'uuid': result.id, 'slug': result.name}) }}"
             class="govuk-link datagovuk-link">{{ result.title }}</a>
        </p>
      {% endfor %}
    {% endif %}
  </div>
{% endblock main %}
