{% extends "base.jinja" %}

{% block page_title %}
  Add harvest source - National Data Library
{% endblock page_title %}

{% block main %}
  <div class="govuk-width-container datagovuk-width-container govuk-!-margin-top-9">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds-from-desktop">
        <h1 class="govuk-heading-xl datagovuk-heading-xl">Add harvest source</h1>
        <form method="post">
          {{ csrf_input }}
          {{ form.as_p() }}
          <button type="submit">Add and harvest now</button>
        </form>
      </div>
    </div>
  </div>
{% endblock main %}
